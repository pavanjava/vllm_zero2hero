        <mxCell id="id2qJ_FwYwP9899kC2al-1" value="Phase-1: CLI arg parsing&lt;div&gt;&lt;span style=&quot;text-align: start; text-wrap-mode: nowrap;&quot;&gt;model ID · tensor_parallel_size=2 · max_model_len=512 · max_seq_len=16&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6a00ff;fontColor=#ffffff;strokeColor=#3700CC;fontFamily=Comic Sans MS;fontSize=13;" parent="1" vertex="1">
