        <mxCell id="6MimTV4tB0RpQHZ1C2n4-212" value="&lt;table class=&quot;min-w-full border-collapse text-sm leading-[1.7] whitespace-normal&quot;&gt;&lt;thead class=&quot;text-left&quot;&gt;&lt;tr&gt;&lt;th scope=&quot;col&quot; class=&quot;text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold&quot;&gt;Term&lt;/th&gt;&lt;th scope=&quot;col&quot; class=&quot;text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold&quot;&gt;Meaning&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;2&lt;/code&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;For both K and V (two matrices)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;num_tokens (16)&lt;/code&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;Sequence length cached in this block&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;num_heads&lt;/code&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;Number of attention heads&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;head_dim&lt;/code&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;Dimension per head (e.g., 128)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;bytes_per_param&lt;/code&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;Precision — fp16=2 bytes, fp32=4 bytes, int8=1 byte&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="940" y="1050" width="430" height="140" as="geometry" />
        </mxCell>
        <mxCell id="6MimTV4tB0RpQHZ1C2n4-213" value="Each block memory = 2 × num_tokens × num_heads × head_dim × bytes_per_param" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="880" y="1002" width="480" height="30" as="geometry" />
        </mxCell>
        <UserObject label="&lt;h3 class=&quot;text-text-100 mt-2 -mb-1 text-base font-bold&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Concrete Example&lt;/font&gt;&lt;/h3&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;b&gt;For a typical LLaMA-style model:&lt;/b&gt;&lt;/font&gt;&lt;/p&gt;&lt;ul class=&quot;[li_&amp;amp;]:mb-0 [li_&amp;amp;]:mt-1 [li_&amp;amp;]:gap-1 [&amp;amp;:not(:last-child)_ul]:pb-1 [&amp;amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3&quot;&gt;&lt;li class=&quot;whitespace-normal break-words pl-2&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;num_tokens = 16&lt;/code&gt;, &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;num_heads = 32&lt;/code&gt;, &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;head_dim = 128&lt;/code&gt;, &lt;code class=&quot;bg-text-200/5 border border-0.5 border-border-300 text-danger-000 whitespace-pre-wrap rounded-[0.4rem] px-1 py-px text-[0.9rem]&quot;&gt;bytes = 2&lt;/code&gt; (fp16)&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;b&gt;Computation&lt;/b&gt;&lt;/div&gt;&lt;ul class=&quot;[li_&amp;amp;]:mb-0 [li_&amp;amp;]:mt-1 [li_&amp;amp;]:gap-1 [&amp;amp;:not(:last-child)_ul]:pb-1 [&amp;amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3&quot;&gt;&lt;li class=&quot;whitespace-normal break-words pl-2&quot;&gt;2 × 16 × 32 × 128 × 2 = 262,144 bytes ≈ 256 KB per layer per block&lt;/li&gt;&lt;/ul&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Multiply this across &lt;strong&gt;all layers&lt;/strong&gt; (e.g., 32 layers) → &lt;strong&gt;~8 MB per block&lt;/strong&gt; across the full model.&lt;/font&gt;&lt;/p&gt;" id="6MimTV4tB0RpQHZ1C2n4-214">
          <mxCell style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
            <mxGeometry x="1520" y="1000" width="500" height="350" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="6MimTV4tB0RpQHZ1C2n4-215" value="&lt;h3 class=&quot;text-text-100 mt-2 -mb-1 text-base font-bold&quot;&gt;Why This Matters&lt;/h3&gt;&lt;ul class=&quot;[li_&amp;amp;]:mb-0 [li_&amp;amp;]:mt-1 [li_&amp;amp;]:gap-1 [&amp;amp;:not(:last-child)_ul]:pb-1 [&amp;amp;:not(:last-child)_ol]:pb-1 list-disc flex flex-col gap-1 pl-8 mb-3&quot;&gt;&lt;li class=&quot;whitespace-normal break-words pl-2&quot;&gt;KV Cache &lt;strong&gt;avoids recomputing&lt;/strong&gt; attention for past tokens during autoregressive decoding&lt;/li&gt;&lt;br&gt;&lt;li class=&quot;whitespace-normal break-words pl-2&quot;&gt;Memory grows &lt;strong&gt;linearly with sequence length&lt;/strong&gt; — long contexts are expensive&lt;/li&gt;&lt;br&gt;&lt;li class=&quot;whitespace-normal break-words pl-2&quot;&gt;Systems like &lt;strong&gt;vLLM use paged attention&lt;/strong&gt; to manage these blocks efficiently, similar to OS virtual memory paging&lt;/li&gt;&lt;/ul&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;This is the core trade-off: &lt;strong&gt;speed (no recomputation) vs. memory (cache storage)&lt;/strong&gt;.&lt;/p&gt;" style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="1520" y="1260" width="560" height="270" as="geometry" />
        </mxCell>
        <mxCell id="6MimTV4tB0RpQHZ1C2n4-217" value="&lt;h3 class=&quot;text-text-100 mt-2 -mb-1 text-base font-bold&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;The Sentence Being Cached&lt;/font&gt;&lt;/h3&gt;&lt;h3 class=&quot;text-text-100 mt-2 -mb-1 text-base font-bold&quot;&gt;&lt;span style=&quot;color: light-dark(rgb(0, 0, 0), rgb(237, 237, 237)); background-color: transparent; font-family: var(--font-mono); text-wrap-mode: wrap; font-size: 12px; font-weight: normal;&quot;&gt;&quot;I am a Language Model trained&quot;&lt;/span&gt;&lt;/h3&gt;&lt;p class=&quot;font-claude-response-body break-words whitespace-normal leading-[1.7]&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;→ &lt;strong&gt;6 tokens&lt;/strong&gt; (one per row)&lt;/font&gt;&lt;/p&gt;" style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="920" y="1210" width="210" height="120" as="geometry" />
        </mxCell>
        <mxCell id="6MimTV4tB0RpQHZ1C2n4-220" value="num_tokens  = 6&#xa;head_dim      = 4&#xa;num_heads   = 2&#xa;num_layers   = 4&#xa;bytes_per_param = 2  (assuming fp16)" style="text;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="1157.13" y="1230" width="240" height="100" as="geometry" />
        </mxCell>
        <mxCell id="6MimTV4tB0RpQHZ1C2n4-221" value="Each block memory&amp;nbsp;= 2 × 6 × 2 × 4 × 2 × 4" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1330" width="250" height="30" as="geometry" />
        </mxCell>
        <UserObject label="&lt;div class=&quot;overflow-x-auto w-full px-2 mb-6&quot;&gt;&lt;table class=&quot;min-w-full border-collapse text-sm leading-[1.7] whitespace-normal&quot;&gt;&lt;thead class=&quot;text-left&quot;&gt;&lt;tr&gt;&lt;th scope=&quot;col&quot; class=&quot;text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Step&lt;/font&gt;&lt;/th&gt;&lt;th scope=&quot;col&quot; class=&quot;text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Operation&lt;/font&gt;&lt;/th&gt;&lt;th scope=&quot;col&quot; class=&quot;text-text-100 border-b-0.5 border-border-300/60 py-2 pr-4 align-top font-bold&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Result&lt;/font&gt;&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;K and V&lt;/font&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;2 × 6&lt;/font&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;12&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;× num_heads&lt;/font&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;12 × 2&lt;/font&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;24&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;× head_dim&lt;/font&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;24 × 4&lt;/font&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;96&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;× bytes (fp16)&lt;/font&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;96 × 2&lt;/font&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;192&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;× num_layers&lt;/font&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;192 × 4&lt;/font&gt;&lt;/td&gt;&lt;td class=&quot;border-b-0.5 border-border-300/30 py-2 pr-4 align-top&quot;&gt;&lt;strong&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;768 bytes&lt;/font&gt;&lt;/strong&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;hr class=&quot;border-border-200 border-t-0.5 my-3 mx-1.5&quot;&gt;&lt;h3 class=&quot;text-text-100 mt-2 -mb-1 text-base font-bold&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Final Answer&lt;/font&gt;&lt;/h3&gt;&lt;div role=&quot;group&quot; aria-label=&quot;Code&quot; tabindex=&quot;0&quot; class=&quot;relative group/copy bg-bg-000/50 border-0.5 border-border-400 rounded-lg focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-100&quot;&gt;&lt;div class=&quot;overflow-x-auto&quot;&gt;&lt;pre class=&quot;code-block__code !my-0 !rounded-lg !text-sm !leading-relaxed p-3.5&quot; style=&quot;background: transparent; font-family: var(--font-mono); color: rgb(234, 236, 240);&quot;&gt;&lt;code style=&quot;background: transparent; font-family: var(--font-mono); white-space: pre-wrap; color: rgb(234, 236, 240);&quot;&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;Total KV Cache Memory = 768 bytes&lt;/font&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;" id="6MimTV4tB0RpQHZ1C2n4-222">
          <mxCell style="text;whiteSpace=wrap;html=1;" vertex="1" parent="1">
            <mxGeometry x="1120" y="1370" width="230" height="250" as="geometry" />
