        <mxCell id="id2qJ_FwYwP9899kC2al-2" value="Phase-2: LLMEngine &amp;amp; SyncLLMEngine Init&lt;div&gt;&lt;span style=&quot;text-align: start; text-wrap-mode: nowrap;&quot;&gt;Spawns executor · detects GPU topology · selects attention backend&lt;/span&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#6d8764;fontColor=#ffffff;strokeColor=#3A5431;fontFamily=Comic Sans MS;fontSize=13;" parent="1" vertex="1">
