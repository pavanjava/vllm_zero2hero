        <mxCell id="TU1oe2ygIfIfvKxFC6g3-10" value="&lt;span style=&quot;color: rgb(255, 255, 255); font-size: 14px; text-align: start; text-wrap-mode: nowrap;&quot;&gt;Session 4 · NVIDIA GPU families, vLLM knobs and other inference platforms&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(255, 255, 255); font-size: 14px; text-align: start; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;75 min · RTX Blackwell (RTX 5090, FP4/FP8, NVLink), A-family (A100 SXM, TF32, BF16),&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(255, 255, 255); font-size: 14px; text-align: start; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;L-family (L40S, ADA Lovelace), H-family (H100, FP8 transformer engine), B-family (Blackwell GB200).&lt;/span&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(255, 255, 255); font-size: 14px; text-align: start; text-wrap-mode: nowrap;&quot;&gt;&lt;span style=&quot;font-size: 12px;&quot;&gt;SGLang, TGI, Ollama&lt;/span&gt;&lt;/span&gt;&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7227E2;strokeColor=#56517e;fontFamily=Comic Sans MS;" parent="1" vertex="1">
