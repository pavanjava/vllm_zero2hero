        </mxCell>
        <mxCell id="uc3" value="&lt;b&gt;Document QA&lt;/b&gt;&#xa;PDF cached, only question varies" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontColor=#4d2d61;" parent="1" vertex="1">
