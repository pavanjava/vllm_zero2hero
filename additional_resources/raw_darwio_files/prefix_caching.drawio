      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="page_title" value="Prefix Caching — Theory &amp; Diagrams" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="20" width="700" height="36" as="geometry" />
        </mxCell>
        <mxCell id="theory_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="68" width="700" height="200" as="geometry" />
        </mxCell>
        <mxCell id="theory_title" value="What is Prefix Caching?" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="100" y="78" width="300" height="24" as="geometry" />
        </mxCell>
        <mxCell id="theory_body" value="Every LLM request runs a &lt;b&gt;prefill phase&lt;/b&gt; that computes Key and Value (KV) tensors for every input token.&#xa;If multiple requests share an identical prefix — such as a system prompt, few-shot examples, or a long document —&#xa;those computations are &lt;b&gt;repeated work&lt;/b&gt;.&#xa;&#xa;Prefix Caching solves this by:&#xa;  1.  Hashing the token sequence of each prefix block.&#xa;  2.  Storing the resulting KV tensors in a GPU memory pool.&#xa;  3.  On a subsequent request, if the hash matches → &lt;b&gt;skip prefill entirely and load the cached KV directly&lt;/b&gt;.&#xa;&#xa;Result: TTFT drops from ~80 ms (full prefill) to ~5 ms (cache load) — roughly 94% reduction." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="100" y="106" width="660" height="148" as="geometry" />
        </mxCell>
        <mxCell id="s1_title" value="Section 1 — Three requests sharing the same system prompt prefix" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="288" width="700" height="26" as="geometry" />
        </mxCell>
        <mxCell id="r1_lbl" value="Request 1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="80" y="320" width="90" height="20" as="geometry" />
        </mxCell>
        <mxCell id="r1_prefix" value="&lt;b&gt;System prompt (512 tokens)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontColor=#235126;" parent="1" vertex="1">
          <mxGeometry x="80" y="342" width="380" height="44" as="geometry" />
