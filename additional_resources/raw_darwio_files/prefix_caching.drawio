          <mxGeometry x="80" y="1185" width="700" height="26" as="geometry" />
        </mxCell>
        <mxCell id="uc1" value="&lt;b&gt;System prompts&lt;/b&gt;&#xa;Same preamble on every request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontColor=#4d2d61;" parent="1" vertex="1">
          <mxGeometry x="80" y="1217" width="160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="uc2" value="&lt;b&gt;Few-shot examples&lt;/b&gt;&#xa;Long demos reused across requests" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontColor=#4d2d61;" parent="1" vertex="1">
