        <mxCell id="s6_title" value="Section 6 — Rules for getting a cache hit" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="1295" width="700" height="26" as="geometry" />
        </mxCell>
        <mxCell id="rules_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="1327" width="700" height="140" as="geometry" />
        </mxCell>
        <mxCell id="rules_body" value="1.  Prefix must be &lt;b&gt;byte-identical&lt;/b&gt; — even one extra space produces a different hash → miss.&#xa;&#xa;2.  Tokens must be &lt;b&gt;contiguous from position 0&lt;/b&gt; — cache is prefix-only, not arbitrary substrings.&#xa;&#xa;3.  Same model + same tokenizer — different quantization means different KV tensor layout.&#xa;&#xa;4.  &lt;b&gt;Block-aligned boundaries&lt;/b&gt; — SGLang / vLLM use 16- or 32-token blocks; the prefix must end on a block boundary for a hit." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="100" y="1337" width="660" height="120" as="geometry" />
        </mxCell>
        <mxCell id="s7_title" value="Section 7 — Engine support" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="1481" width="700" height="26" as="geometry" />
        </mxCell>
        <mxCell id="eng1" value="&lt;b&gt;SGLang&lt;/b&gt;&#xa;On by default" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="80" y="1513" width="150" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eng2" value="&lt;b&gt;vLLM&lt;/b&gt;&#xa;--enable-prefix-caching flag" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="244" y="1513" width="170" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eng3" value="&lt;b&gt;Ollama&lt;/b&gt;&#xa;Automatic — zero config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="428" y="1513" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eng4" value="&lt;b&gt;TGI (HuggingFace)&lt;/b&gt;&#xa;Partial support" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="602" y="1513" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s8_title" value="Section 8 — How Prefix Caching + Chunked Prefill compose" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="1579" width="700" height="26" as="geometry" />
        </mxCell>
        <mxCell id="compose_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="1611" width="700" height="90" as="geometry" />
        </mxCell>
        <mxCell id="compose_body" value="On a &lt;b&gt;cache miss&lt;/b&gt;: Chunked Prefill processes the long prefix in small chunks (e.g. 512 tokens at a time), &#xa;interleaving decode steps so other requests are not starved. Each chunk&#39;s KV is stored in the cache.&#xa;&#xa;On a &lt;b&gt;cache hit&lt;/b&gt;: The cached prefix is loaded directly — Chunked Prefill never runs for that portion. &#xa;Only the new suffix (user query) goes through prefill, which is tiny and needs no chunking." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="100" y="1621" width="660" height="70" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
