        <mxCell id="lru_note" value="When GPU memory is full, the least-recently-used prefix block is dropped to make room for new cache entries." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#666666;" parent="1" vertex="1">
