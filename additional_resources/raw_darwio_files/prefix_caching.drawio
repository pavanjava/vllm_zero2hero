        <mxCell id="uc4" value="&lt;b&gt;Multi-turn chat&lt;/b&gt;&#xa;Conversation history prefix cached" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontColor=#4d2d61;" parent="1" vertex="1">
          <mxGeometry x="602" y="1217" width="160" height="60" as="geometry" />
