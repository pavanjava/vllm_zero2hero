            <mxPoint x="250" y="1619" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="sc_pf_fleet" value="&lt;b&gt;Prefill Fleet&lt;/b&gt;&#xa;P-node 1&#xa;P-node 2&#xa;P-node 3&#xa;P-node N  (scale up for long prompts)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="80" y="1621" width="260" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sc_kv_arr" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#d6b656;dashed=1;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="342" y="1676" as="sourcePoint" />
            <mxPoint x="598" y="1676" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="sc_kv_lbl" value="KV transfer" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#d6b656;" parent="1" vertex="1">
          <mxGeometry x="390" y="1657" width="82" height="16" as="geometry" />
        </mxCell>
        <mxCell id="sc_arr2" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#82b366;" parent="1" edge="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="590" y="1589" as="sourcePoint" />
            <mxPoint x="690" y="1619" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="sc_dc_fleet" value="&lt;b&gt;Decode Fleet&lt;/b&gt;&#xa;D-node 1&#xa;D-node 2&#xa;D-node 3&#xa;D-node M  (scale up for long outputs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontColor=#235126;" parent="1" vertex="1">
          <mxGeometry x="600" y="1621" width="260" height="110" as="geometry" />
        </mxCell>
        <mxCell id="sc_note" value="Scale prefill nodes for long-prompt workloads (RAG, document QA).  Scale decode nodes for long-generation workloads (code, creative writing).  With coupled serving you can only scale the entire GPU pool uniformly." style="text;html=1;strokeColor=none;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;align=left;verticalAlign=middle;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="80" y="1747" width="780" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s5_title" value="Section 5 — Trade-offs" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="1826" width="860" height="26" as="geometry" />
        </mxCell>
        <mxCell id="pros_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="80" y="1858" width="400" height="170" as="geometry" />
        </mxCell>
        <mxCell id="pros_title" value="Benefits" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#235126;" parent="1" vertex="1">
          <mxGeometry x="100" y="1868" width="200" height="22" as="geometry" />
        </mxCell>
        <mxCell id="pros_body" value="+ Lower TTFT — prefill no longer blocks decode&#xa;+ Higher token throughput — decode runs unblocked&#xa;+ Independent scaling — scale P or D fleet separately&#xa;+ GPU specialisation — right hardware for each job&#xa;+ Better SLA predictability — each phase isolated&#xa;+ Enables heterogeneous clusters (cheap D-nodes)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;whiteSpace=wrap;fontColor=#235126;" parent="1" vertex="1">
          <mxGeometry x="100" y="1894" width="370" height="124" as="geometry" />
        </mxCell>
        <mxCell id="cons_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="500" y="1858" width="440" height="170" as="geometry" />
        </mxCell>
        <mxCell id="cons_title" value="Costs and challenges" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="520" y="1868" width="260" height="22" as="geometry" />
        </mxCell>
        <mxCell id="cons_body" value="- Network hop adds ~1–5 ms to TTFT (the KV transfer)&#xa;- Requires high-speed interconnect (RDMA / NVLink)&#xa;- More infrastructure complexity — two separate fleets&#xa;- Cold-start penalty on first request to a cold P-node&#xa;- Harder to implement — KV must be serialised/sent&#xa;- Potential for network bottleneck under bursty load" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;whiteSpace=wrap;fontColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="520" y="1894" width="410" height="124" as="geometry" />
        </mxCell>
        <mxCell id="s6_title" value="Section 6 — GPU Selection Guide for Each Role" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="2044" width="860" height="26" as="geometry" />
        </mxCell>
        <mxCell id="gpu_p" value="&lt;b&gt;Prefill Node GPU Profile&lt;/b&gt;&#xa;&#xa;Priority: highest FLOPS&#xa;HBM size: less critical&#xa;&#xa;Best fit:&#xa;  H100 SXM (80 GB)&#xa;  A100 SXM (80 GB)&#xa;  B200&#xa;&#xa;Why: prefill is compute-bound.&#xa;More CUDA cores = faster prefill." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="80" y="2076" width="260" height="190" as="geometry" />
        </mxCell>
        <mxCell id="gpu_d" value="&lt;b&gt;Decode Node GPU Profile&lt;/b&gt;&#xa;&#xa;Priority: highest HBM bandwidth&#xa;FLOPS: less critical&#xa;&#xa;Best fit:&#xa;  H100 NVL (94 GB)&#xa;  A100 PCIe (80 GB)&#xa;  L40S (48 GB, cheaper)&#xa;&#xa;Why: decode is memory-BW-bound.&#xa;More HBM = more concurrent sequences." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontColor=#235126;" parent="1" vertex="1">
          <mxGeometry x="360" y="2076" width="260" height="190" as="geometry" />
        </mxCell>
        <mxCell id="gpu_net" value="&lt;b&gt;Network Requirements&lt;/b&gt;&#xa;&#xa;Minimum: 100 Gb/s Ethernet&#xa;Recommended: 400 Gb/s InfiniBand&#xa;Ideal: NVLink (same server)&#xa;&#xa;Rule of thumb:&#xa;  KV size (GB) / bandwidth (GB/s)&#xa;  = transfer latency&#xa;&#xa;400 Gb/s = 50 GB/s&#xa;2 GB KV / 50 GB/s = 40 ms  (TCP)&#xa;2 GB KV / 50 GB/s = 5 ms   (RDMA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontColor=#7d6608;" parent="1" vertex="1">
          <mxGeometry x="640" y="2076" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="s7_title" value="Section 7 — Engine / System Support" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="2347" width="860" height="26" as="geometry" />
        </mxCell>
        <mxCell id="eng_sglang" value="&lt;b&gt;SGLang&lt;/b&gt;&#xa;First-class disaggregated serving.&#xa;Paged KV block transfer.&#xa;Prefix caching works across P/D." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="80" y="2379" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="eng_vllm" value="&lt;b&gt;vLLM&lt;/b&gt;&#xa;Disaggregated P/D in active development.&#xa;Experimental support in recent versions." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="284" y="2379" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="eng_mooncake" value="&lt;b&gt;Mooncake (Moonshot AI)&lt;/b&gt;&#xa;Purpose-built disaggregated serving system.&#xa;Production at Kimi (Moonshot)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="488" y="2379" width="190" height="80" as="geometry" />
        </mxCell>
        <mxCell id="eng_distserve" value="&lt;b&gt;DistServe (academic)&lt;/b&gt;&#xa;Research system purpose-built for disaggregated serving. Source of many design ideas." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="692" y="2379" width="248" height="80" as="geometry" />
        </mxCell>
        <mxCell id="s8_title" value="Section 8 — How Disaggregated P/D Composes with Chunked Prefill and Prefix Caching" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="2475" width="860" height="26" as="geometry" />
        </mxCell>
        <mxCell id="compose_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="80" y="2507" width="860" height="170" as="geometry" />
        </mxCell>
        <mxCell id="compose_body" value="&lt;b&gt;With Chunked Prefill:&lt;/b&gt;  On a cache miss, the prefill node processes the long prompt in 512-token chunks. Each chunk&#39;s KV is appended to the growing tensor. Once all chunks are done, the full KV is transferred to the decode node. Chunked prefill ensures the prefill node stays responsive to the scheduler during long prefills.&#xa;&#xa;&lt;b&gt;With Prefix Caching:&lt;/b&gt;  If the system prompt prefix is already cached on the prefill node, its KV blocks are reused — only the new suffix KV needs to be computed and transferred. This dramatically reduces KV transfer size and further cuts TTFT. Some systems cache KV on the decode node directly so even the transfer is skipped on a full hit.&#xa;&#xa;&lt;b&gt;Combined:&lt;/b&gt;  Production systems like SGLang and Mooncake run all three — disaggregated P/D + chunked prefill on the prefill node + prefix caching on both nodes — to maximise throughput and minimise TTFT simultaneously." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="100" y="2517" width="820" height="110" as="geometry" />
        </mxCell>
        <mxCell id="coupled_req_lbl" value="Request" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="200" y="460" width="100" height="14" as="geometry" />
        </mxCell>
        <mxCell id="oz17IB7DdtjIUk_jMaiu-5" value="NVLink" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="441" y="1681" width="82" height="16" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
