        <mxCell id="c2" value="C2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontColor=#235126;fontStyle=1;" parent="1" vertex="1">
