        <mxCell id="fcfs_qc" value="Req C  (t=2s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="80" y="526" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fcfs_slot_lbl" value="Active GPU Slots" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#666666;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="260" y="432" width="130" height="16" as="geometry" />
        </mxCell>
        <mxCell id="fcfs_s1" value="Slot 1  ✓ Done (Req A)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontColor=#235126;" parent="1" vertex="1">
          <mxGeometry x="260" y="450" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fcfs_s2" value="Slot 2  →  Req B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="260" y="488" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fcfs_s3" value="Slot 3  →  Req C (resumed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="260" y="526" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fcfs_kv_lbl" value="KV Cache state" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#666666;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="574" width="120" height="16" as="geometry" />
        </mxCell>
        <mxCell id="fcfs_kv_gpu" value="GPU Memory — 70% used" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontColor=#235126;" parent="1" vertex="1">
          <mxGeometry x="80" y="592" width="360" height="26" as="geometry" />
        </mxCell>
        <mxCell id="fcfs_kv_cpu" value="CPU Swap — holds paused KV blocks (Req C was swapped out, now resumed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#7d6608;" parent="1" vertex="1">
          <mxGeometry x="80" y="626" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="fcfs_rule" value="FCFS rule: when GPU memory fills, the &lt;b&gt;newest&lt;/b&gt; (latest arrival) request is preempted first. KV blocks swapped to CPU. Resumed when space frees." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;" parent="1" vertex="1">
          <mxGeometry x="80" y="662" width="361" height="47" as="geometry" />
        </mxCell>
        <mxCell id="pri_hdr" value="&lt;b&gt;Alternative: Priority Scheduling&lt;/b&gt;&#xa;Set via: policy = SchedulerPolicy.PRIORITY. Lower number = higher priority (served first)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="480" y="372" width="360" height="50" as="geometry" />
        </mxCell>
        <mxCell id="pri_q_lbl" value="Priority Queue" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#666666;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="480" y="432" width="130" height="16" as="geometry" />
        </mxCell>
        <mxCell id="pri_qx" value="Req X   priority=1  (highest)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="480" y="450" width="200" height="30" as="geometry" />
