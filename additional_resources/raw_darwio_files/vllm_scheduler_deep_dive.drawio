        <mxCell id="c5" value="C5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="362" y="1024" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="c6" value="C6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="430" y="1024" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="c7" value="C7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" parent="1" vertex="1">
