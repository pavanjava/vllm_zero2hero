        <mxCell id="eq" value="=" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="466" y="766" width="30" height="40" as="geometry" />
        </mxCell>
        <mxCell id="total_tok" value="&lt;b&gt;30,000 total tokens&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="508" y="756" width="210" height="60" as="geometry" />
        </mxCell>
        <mxCell id="lim1" value="max-model-len = 16,000   →   30,000 &gt; 16,000   →   EXCEEDS — request rejected at admission" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontColor=#b85450;align=left;" parent="1" vertex="1">
          <mxGeometry x="80" y="832" width="638" height="34" as="geometry" />
        </mxCell>
        <mxCell id="lim2" value="max-num-batched-tokens = 12,000   →   30,000 &gt; 12,000   →   EXCEEDS — single iteration cannot process this" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontColor=#b85450;align=left;" parent="1" vertex="1">
          <mxGeometry x="80" y="874" width="638" height="34" as="geometry" />
        </mxCell>
        <mxCell id="fail_note" value="Root cause: the request violates BOTH limits simultaneously. No matter how you tune one flag, the other still blocks it. The fix is not a bigger limit — it is breaking the request into chunks." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;align=left;" parent="1" vertex="1">
          <mxGeometry x="80" y="918" width="638" height="40" as="geometry" />
        </mxCell>
        <mxCell id="s4_lbl" value="Section 4 — The Fix: Chunked Prefill (vLLM V1 default)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="974" width="700" height="24" as="geometry" />
        </mxCell>
        <mxCell id="s4_sub" value="30,000 token request split into 8 chunks of ~3,750 tokens each (chunk size ≤ max-num-batched-tokens minus decode budget)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontColor=#666666;" parent="1" vertex="1">
          <mxGeometry x="80" y="998" width="720" height="18" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="C1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontColor=#235126;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="1024" width="60" height="30" as="geometry" />
