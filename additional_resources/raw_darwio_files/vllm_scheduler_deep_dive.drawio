        <mxCell id="pri_qy" value="Req Y   priority=5  (lowest)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="480" y="526" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="pri_slot_lbl" value="Active Slots" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=11;fontColor=#666666;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="700" y="432" width="100" height="16" as="geometry" />
        </mxCell>
        <mxCell id="pri_s1" value="Slot 1  →  Req X (priority=1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="700" y="450" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="pri_s2" value="Slot 2  →  Req Z (priority=3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#7d6608;" parent="1" vertex="1">
          <mxGeometry x="700" y="488" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="pri_s3" value="Slot 3  →  Req Y (priority=5 — preempt first)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="700" y="526" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="pri_rule" value="Priority rule: when GPU memory fills, the &lt;b&gt;lowest-priority&lt;/b&gt; request is preempted first (highest number = evicted first), regardless of arrival time." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;" parent="1" vertex="1">
          <mxGeometry x="480" y="566" width="419" height="45" as="geometry" />
        </mxCell>
        <mxCell id="s3_lbl" value="Section 3 — The Failure: 30k Token Request (Qwen 3.5 Vision, video input)" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="724" width="800" height="24" as="geometry" />
        </mxCell>
        <mxCell id="vis_tok" value="&lt;b&gt;Visual tokens&lt;/b&gt;&#xa;18,000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="80" y="756" width="160" height="60" as="geometry" />
        </mxCell>
