        <mxCell id="slot3" value="Slot 3  →  Prefill chunk C4  (fills remaining budget)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#7d6608;" parent="1" vertex="1">
