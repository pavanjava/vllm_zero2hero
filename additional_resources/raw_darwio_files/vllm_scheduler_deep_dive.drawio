        </mxCell>
        <mxCell id="it2_lbl" value="Iteration 2 — budget: 12,000 tokens total  |  Decode gets priority: 2,000 tokens  |  Prefill chunk fills remaining: 10,000 tokens" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontColor=#235126;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="1064" width="760" height="18" as="geometry" />
        </mxCell>
        <mxCell id="slot1" value="Slot 1  →  Decode D  (existing request — priority)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontColor=#4d2d61;" parent="1" vertex="1">
