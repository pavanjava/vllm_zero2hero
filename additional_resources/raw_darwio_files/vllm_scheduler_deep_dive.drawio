          <mxGeometry x="252" y="766" width="30" height="40" as="geometry" />
        </mxCell>
        <mxCell id="txt_tok" value="&lt;b&gt;Text tokens&lt;/b&gt;&#xa;12,000" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontColor=#7d6608;" parent="1" vertex="1">
          <mxGeometry x="294" y="756" width="160" height="60" as="geometry" />
