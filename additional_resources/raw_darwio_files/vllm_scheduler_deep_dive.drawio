        <mxCell id="slot4" value="Slot 4  →  Prefill chunk C5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="80" y="1204" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="slot5" value="Slot 5  →  Prefill chunk C6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="80" y="1242" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="achieved_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
          <mxGeometry x="480" y="1090" width="380" height="190" as="geometry" />
        </mxCell>
        <mxCell id="achieved_title" value="What chunked prefill achieves" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=13;fontStyle=1;fontColor=#235126;" parent="1" vertex="1">
          <mxGeometry x="500" y="1100" width="340" height="20" as="geometry" />
        </mxCell>
        <mxCell id="achieved_body" value="1.  30k request no longer exceeds any single limit —&#xa;    each chunk is ≤ 12,000 tokens.&#xa;&#xa;2.  Decode requests are processed FIRST each iteration&#xa;    → better inter-token latency (ITL).&#xa;&#xa;3.  Remaining token budget goes to prefill chunks&#xa;    → GPU always fully utilised.&#xa;&#xa;4.  Enabled by default in vLLM V1." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=12;whiteSpace=wrap;fontColor=#235126;" parent="1" vertex="1">
          <mxGeometry x="500" y="1124" width="350" height="138" as="geometry" />
        </mxCell>
        <mxCell id="s5_lbl" value="Section 5 — Summary: How the Scheduler Makes Decisions Each Iteration" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=15;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="80" y="1290" width="780" height="24" as="geometry" />
        </mxCell>
        <mxCell id="th1" value="Question the scheduler asks" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="80" y="1320" width="300" height="32" as="geometry" />
        </mxCell>
        <mxCell id="th2" value="Limit that answers it" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="382" y="1320" width="200" height="32" as="geometry" />
        </mxCell>
        <mxCell id="th3" value="What happens when exceeded" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;fontColor=#0c447c;" parent="1" vertex="1">
          <mxGeometry x="584" y="1320" width="276" height="32" as="geometry" />
        </mxCell>
        <mxCell id="tr1c1" value="Can this request ever run on this model?" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="80" y="1354" width="300" height="32" as="geometry" />
        </mxCell>
        <mxCell id="tr1c2" value="--max-model-len" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=11;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="382" y="1354" width="200" height="32" as="geometry" />
        </mxCell>
        <mxCell id="tr1c3" value="Request rejected immediately at admission" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontColor=#b85450;" parent="1" vertex="1">
          <mxGeometry x="584" y="1354" width="276" height="32" as="geometry" />
        </mxCell>
        <mxCell id="tr2c1" value="How many tokens can this iteration process?" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=11;" parent="1" vertex="1">
          <mxGeometry x="80" y="1388" width="300" height="32" as="geometry" />
        </mxCell>
        <mxCell id="tr2c2" value="--max-num-batched-tokens" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#aaaaaa;fontSize=11;fontStyle=1;" parent="1" vertex="1">
          <mxGeometry x="382" y="1388" width="200" height="32" as="geometry" />
